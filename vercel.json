{
  "buildCommand": "node build.js",
  "outputDirectory": "dist",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.hammadmedia.com"
        }
      ],
      "destination": "https://hammadmedia.com/:path*",
      "permanent": true
    }
  ]
}
